##########
# any_value aggregate tests
##########

# any_value is non-deterministic; pin to a single partition so the row that
# wins each group is stable for these assertions.
statement ok
set datafusion.execution.target_partitions = 1;

statement ok
CREATE TABLE tags(id INT, tag VARCHAR, val INT) AS VALUES
  (1, 'a', 10),
  (1, 'b', 20),
  (2, 'c', 30),
  (2, 'd', 40),
  (3, NULL, NULL),
  (3, 'e', 50);

# Grouped by a unique id: get one tag and one val per group.
# any_value ignores NULLs, so group 3 returns the non-null 'e'/50.
query ITI rowsort
SELECT id, any_value(tag), any_value(val) FROM tags GROUP BY id;
----
1 a 10
2 c 30
3 e 50

# A group whose values are all NULL returns NULL.
statement ok
CREATE TABLE all_null(id INT, v INT) AS VALUES (1, NULL), (1, NULL);

query II
SELECT id, any_value(v) FROM all_null GROUP BY id;
----
1 NULL

# Global aggregate (no GROUP BY).
query I
SELECT any_value(val) FROM tags;
----
10

# any_value over a single literal column.
query I
SELECT any_value(column1) FROM (VALUES (42), (43), (44));
----
42

statement ok
DROP TABLE tags;

statement ok
DROP TABLE all_null;

statement ok
set datafusion.execution.target_partitions = 4;
