# =====================================================
# Test with single row per category (edge case)
# =====================================================

statement ok
CREATE TABLE single_row_categories (
    category VARCHAR,
    revenue INT
) AS VALUES
    ('alpha', 100),
    ('bravo', 200),
    ('charlie', 300),
    ('delta', 400),
    ('echo', 500);

# Each category has exactly 1 row, K=1
query TI
SELECT category, revenue
FROM (
    SELECT
        category,
        revenue,
        ROW_NUMBER() OVER (PARTITION BY category ORDER BY revenue DESC) as rn
    FROM single_row_categories
) t
WHERE rn <= 1
ORDER BY category;
----
alpha 100
bravo 200
charlie 300
delta 400
echo 500

# Each category has exactly 1 row, K=10 (K > partition size)
query TI
SELECT category, revenue
FROM (
    SELECT
        category,
        revenue,
        ROW_NUMBER() OVER (PARTITION BY category ORDER BY revenue DESC) as rn
    FROM single_row_categories
) t
WHERE rn <= 10
ORDER BY category;
----
alpha 100
bravo 200
charlie 300
delta 400
echo 500

# Verify optimization is still applied for single-row partitions
query TT
EXPLAIN SELECT category, revenue
FROM (
    SELECT
        category,
        revenue,
        ROW_NUMBER() OVER (PARTITION BY category ORDER BY revenue DESC) as rn
    FROM single_row_categories
) t
WHERE rn <= 1;
----
logical_plan
01)SubqueryAlias: t
02)--Projection: single_row_categories.category, single_row_categories.revenue
03)----Filter: row_number() PARTITION BY [single_row_categories.category] ORDER BY [single_row_categories.revenue DESC NULLS FIRST] RANGE BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW <= UInt64(1)
04)------WindowAggr: windowExpr=[[row_number() PARTITION BY [single_row_categories.category] ORDER BY [single_row_categories.revenue DESC NULLS FIRST] RANGE BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW]]
05)--------TableScan: single_row_categories projection=[category, revenue]
physical_plan
01)FilterExec: row_number() PARTITION BY [single_row_categories.category] ORDER BY [single_row_categories.revenue DESC NULLS FIRST] RANGE BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW@2 <= 1, projection=[category@0, revenue@1]
02)--BoundedWindowAggExec: wdw=[row_number() PARTITION BY [single_row_categories.category] ORDER BY [single_row_categories.revenue DESC NULLS FIRST] RANGE BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW: Field { "row_number() PARTITION BY [single_row_categories.category] ORDER BY [single_row_categories.revenue DESC NULLS FIRST] RANGE BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW": UInt64 }, frame: RANGE BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW], mode=[Sorted]
03)----PartitionedTopKSortExec: partition_by=[category@0 ASC NULLS LAST], order_by=[revenue@1 DESC], fetch=1
04)------DataSourceExec: partitions=1, partition_sizes=[1]

statement ok
DROP TABLE single_row_categories;

# =====================================================
# Test correctness: compare optimized vs unoptimized
# results on interleaved multi-batch input
# =====================================================

statement ok
CREATE TABLE interleaved_test (
    category VARCHAR,
    product VARCHAR,
    revenue INT
) AS VALUES
    ('X', 'x1', 500), ('Y', 'y1', 600), ('Z', 'z1', 100),
    ('X', 'x2', 300), ('Y', 'y2', 400), ('Z', 'z2', 700),
    ('X', 'x3', 100), ('Y', 'y3', 200), ('Z', 'z3', 300),
    ('X', 'x4', 700), ('Y', 'y4', 800), ('Z', 'z4', 500),
    ('X', 'x5', 200), ('Y', 'y5', 100), ('Z', 'z5', 900);

# Get top 2 per category with optimization enabled
query TTI
SELECT category, product, revenue
FROM (
    SELECT
        category,
        product,
        revenue,
        ROW_NUMBER() OVER (PARTITION BY category ORDER BY revenue DESC) as rn
    FROM interleaved_test
) t
WHERE rn <= 2
ORDER BY category, revenue DESC;
----
X x4 700
X x1 500
Y y4 800
Y y1 600
Z z5 900
Z z2 700

# Disable optimization and verify same results
statement ok
SET datafusion.optimizer.enable_window_topk = false;

query TTI
SELECT category, product, revenue
FROM (
    SELECT
        category,
        product,
        revenue,
        ROW_NUMBER() OVER (PARTITION BY category ORDER BY revenue DESC) as rn
    FROM interleaved_test
) t
WHERE rn <= 2
ORDER BY category, revenue DESC;
----
X x4 700
X x1 500
Y y4 800
Y y1 600
Z z5 900
Z z2 700

statement ok
SET datafusion.optimizer.enable_window_topk = true;

statement ok
DROP TABLE interleaved_test;
