# K larger than rows per category (should return all rows)
query TI
SELECT category, revenue
FROM (
    SELECT
        category,
        revenue,
        ROW_NUMBER() OVER (PARTITION BY category ORDER BY revenue DESC) as rn
    FROM many_categories
) t
WHERE rn <= 10
ORDER BY category, revenue DESC;
